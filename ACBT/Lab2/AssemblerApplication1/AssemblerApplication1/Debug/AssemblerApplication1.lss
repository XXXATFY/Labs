                                 .equ	TWA1	= 2	; TWI (Slave) Address register Bit 1
                                 .equ	TWA2	= 3	; TWI (Slave) Address register Bit 2
                                 .equ	TWA3	= 4	; TWI (Slave) Address register Bit 3
                                 .equ	TWA4	= 5	; TWI (Slave) Address register Bit 4
                                 .equ	TWA5	= 6	; TWI (Slave) Address register Bit 5
                                 .equ	TWA6	= 7	; TWI (Slave) Address register Bit 6
                                 
                                 
                                 
                                 ; ***** LOCKSBITS ********************************************************
                                 .equ	LB1	= 0	; Lock bit
                                 .equ	LB2	= 1	; Lock bit
                                 .equ	BLB01	= 2	; Boot Lock bit
                                 .equ	BLB02	= 3	; Boot Lock bit
                                 .equ	BLB11	= 4	; Boot lock bit
                                 .equ	BLB12	= 5	; Boot lock bit
                                 
                                 
                                 ; ***** FUSES ************************************************************
                                 ; LOW fuse bits
                                 .equ	CKSEL0	= 0	; Select Clock Source
                                 .equ	CKSEL1	= 1	; Select Clock Source
                                 .equ	CKSEL2	= 2	; Select Clock Source
                                 .equ	CKSEL3	= 3	; Select Clock Source
                                 .equ	BODEN	= 6	; Brown out detector enable
                                 .equ	BODLEVEL	= 7	; Brown out detector trigger level
                                 
                                 ; HIGH fuse bits
                                 .equ	BOOTRST	= 0	; Select Reset Vector
                                 .equ	BOOTSZ0	= 1	; Select Boot Size
                                 .equ	BOOTSZ1	= 2	; Select Boot Size
                                 .equ	EESAVE	= 3	; EEPROM memory is preserved through chip erase
                                 .equ	SPIEN	= 5	; Enable Serial programming and Data Downloading
                                 .equ	JTAGEN	= 6	; Enable JTAG
                                 .equ	OCDEN	= 7	; Enable OCD
                                 
                                 
                                 
                                 ; ***** CPU REGISTER DEFINITIONS *****************************************
                                 .def	XH	= r27
                                 .def	XL	= r26
                                 .def	YH	= r29
                                 .def	YL	= r28
                                 .def	ZH	= r31
                                 .def	ZL	= r30
                                 
                                 
                                 
                                 ; ***** DATA MEMORY DECLARATIONS *****************************************
                                 .equ	FLASHEND	= 0x3fff	; Note: Word address
                                 .equ	IOEND	= 0x003f
                                 .equ	SRAM_START	= 0x0060
                                 .equ	SRAM_SIZE	= 2048
                                 .equ	RAMEND	= 0x085f
                                 .equ	XRAMEND	= 0x0000
                                 .equ	E2END	= 0x03ff
                                 .equ	EEPROMEND	= 0x03ff
                                 .equ	EEADRBITS	= 10
                                 #pragma AVRPART MEMORY PROG_FLASH 32768
                                 #pragma AVRPART MEMORY EEPROM 1024
                                 #pragma AVRPART MEMORY INT_SRAM SIZE 2048
                                 #pragma AVRPART MEMORY INT_SRAM START_ADDR 0x60
                                 
                                 
                                 
                                 ; ***** BOOTLOADER DECLARATIONS ******************************************
                                 .equ	NRWW_START_ADDR	= 0x3800
                                 .equ	NRWW_STOP_ADDR	= 0x3fff
                                 .equ	RWW_START_ADDR	= 0x0
                                 .equ	RWW_STOP_ADDR	= 0x37ff
                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	INT2addr	= 0x0006	; External Interrupt Request 2
                                 .equ	OC2addr	= 0x0008	; Timer/Counter2 Compare Match
                                 .equ	OVF2addr	= 0x000a	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x000c	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x000e	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0010	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x0012	; Timer/Counter1 Overflow
                                 .equ	OC0addr	= 0x0014	; Timer/Counter0 Compare Match
                                 .equ	OVF0addr	= 0x0016	; Timer/Counter0 Overflow
                                 .equ	SPIaddr	= 0x0018	; Serial Transfer Complete
                                 .equ	URXCaddr	= 0x001a	; USART, Rx Complete
                                 .equ	UDREaddr	= 0x001c	; USART Data Register Empty
                                 .equ	UTXCaddr	= 0x001e	; USART, Tx Complete
                                 .equ	ADCCaddr	= 0x0020	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x0022	; EEPROM Ready
                                 .equ	ACIaddr	= 0x0024	; Analog Comparator
                                 .equ	TWIaddr	= 0x0026	; 2-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0028	; Store Program Memory Ready
                                 
                                 .equ	INT_VECTORS_SIZE	= 42	; size in words
                                 
                                 #endif  /* _M32DEF_INC_ */
                                 
                                 
                                 .def VAR_Y      = R22	; ŪĒÓ„ÕĒĶÕ y
                                 .def STATE      = R23	; čŅ±“Ņ ĒĶÕ ŃĶ­ļ Ēõ¹ 1\0
                                 .def MODE       = R24 	; ąÕµĶņ ­ÓßŅ“¹ ŃĶ­ļ Ēõ¹
                                 .def VAL1       = R25 	; ŪĒÓ„ÕĒĶÕ Ō¹ŌŅõĶņŅÕ ĒÓ ’Ņ­“ PORTA
                                 .def VAL2       = R19 	; ŪĒÓ„ÕĒĶÕ Ō¹ŌŅõĶņŅÕ ĒÓ ’Ņ­“ PORTB
                                 .def NEG_VAR_Y  = R18	; Ž­ ņŅķ ĻŅõ y
                                 .def LAST_Y     = R17	; Ž­Ņ°ļŅÕ ńĒÓ„ÕĒĶÕ Y
                                 .def INPUT_LOCK = R26	; ┴ļŅĻĶ­ŅŌĻÓ ŌŌŅõÓ õŅ Ņ“’¾±ĻÓ Ō±Õ§ ĻĒŅ’ŅĻ ŌŌŅõ
                                 
                                 .equ EE_MODE_ADDR = 0x00
                                 
                                 .org $000 
000000 940c 0034                    JMP reset
                                 .org INT0addr
000002 940c 00c8                    JMP EXT_INT0
                                 .org INT1addr
000004 940c 00d3                    JMP EXT_INT1
                                 
                                 
                                 ; =====================================================
                                 ; Ū└─┼ąŲ╩└ 10 ņ±
                                 ; =====================================================
                                 delay_10ms:
000006 ece1                         LDI  R30, 193
000007 e6d5                         LDI  R29, 101
                                 delay_10ms_sb:
000008 0000                         NOP
000009 95da                         DEC  R29
00000a 0000                         NOP
00000b f7e1                         BRNE delay_10ms_sb
00000c 95e3                         INC  R30
00000d f7d1                         BRNE delay_10ms_sb
00000e 0000                         NOP
00000f 0000                         NOP
000010 0000                         NOP
000011 0000                         NOP
000012 9508                         RET
                                 
                                 ; =====================================================
                                 ; Ū└─┼ąŲ╩└ 250 ņ± (25 ­Óń ’Ņ 10 ņ±)
                                 ; =====================================================
                                 delay:
000013 e149                         LDI  TMP, 25         ; ŽŅŌ“Ņ­ Õ“ delay 25 ­Óń 
                                 delay_sb:
000014 940e 0006                    CALL delay_10ms
000016 954a                         DEC  TMP
000017 f7e1                         BRNE delay_sb
000018 9508                         RET
                                 
                                 
                                 ; =====================================================
                                 ; EEPROM
                                 ; =====================================================
                                 eeprom_read:
000019 99e1                         SBIC EECR, EEWE
00001a cffe                         RJMP eeprom_read
                                 
00001b 2744                         CLR TMP
00001c bb4f                         OUT EEARH, TMP
00001d bb4e                         OUT EEARL, TMP
                                 
00001e 9ae0                         SBI EECR, EERE
00001f b38d                         IN  MODE, EEDR
                                 
000020 3081                         CPI MODE, 0x01
000021 f029                         BREQ eeprom_read_ok
000022 3082                         CPI MODE, 0x02
000023 f019                         BREQ eeprom_read_ok
000024 3083                         CPI MODE, 0x03
000025 f009                         BREQ eeprom_read_ok
000026 e081                         LDI MODE, 0x01
                                 eeprom_read_ok:
000027 9508                         RET
                                 
                                 
                                 eeprom_write:
000028 99e1                         SBIC EECR, EEWE
000029 cffe                         RJMP eeprom_write
                                 
00002a 2744                         CLR TMP
00002b bb4f                         OUT EEARH, TMP
00002c bb4e                         OUT EEARL, TMP
00002d bb8d                         OUT EEDR, MODE
                                 
00002e b74f                         IN  TMP, SREG
00002f 94f8                         CLI
000030 9ae2                         SBI EECR, EEMWE
000031 9ae1                         SBI EECR, EEWE
000032 bf4f                         OUT SREG, TMP
000033 9508                         RET
                                 
                                 
                                 ; =====================================================
                                 ; RESET
                                 ; =====================================================
                                 reset:
                                    ; ═Ó±“­ŅķĻÓ ±“ÕĻÓ
000034 e048                         LDI  TMP, HIGH(RAMEND)
000035 bf4e                         OUT  SPH, TMP  
000036 e54f                         LDI  TMP, LOW(RAMEND)
000037 bf4d                         OUT  SPL, TMP 
                                 
                                    ; PORTC - Ō§Ņõ
000038 2744                         CLR  TMP
000039 bb44                         OUT  DDRC, TMP
00003a bb45                         OUT  PORTC, TMP
                                    
                                    ; PORTD: PD0,PD1,PD4,PD5,PD6 - Ō¹§Ņõ
                                    ; PD2,PD3,PD7 - Ō§Ņõ
00003b e743                         LDI  TMP, 0x73
00003c bb41                         OUT  DDRD, TMP
00003d 2744                         CLR  TMP
00003e bb42                         OUT  PORTD, TMP
                                    
                                    ; PORTA, PORTB - Ō¹§Ņõ
00003f ef4f                         SER  TMP
000040 bb4a                         OUT  DDRA, TMP
000041 bb47                         OUT  DDRB, TMP 
                                    
                                    ; ĒÓ„Óļ³Ē¹Õ ńĒÓ„ÕĒĶ 
000042 e761                         LDI VAR_Y, 0x71
000043 e0a0                         LDI INPUT_LOCK, 0x00
000044 e070                         LDI STATE, 0x00
                                 
                                    ; MODE „Ķ“ÓÕņ Ķń EEPROM
000045 940e 0019                    CALL eeprom_read
                                 
000047 940e 00b0                    CALL mode_show
000049 940e 00b5                    CALL state_show
00004b 940e 00bf                    CALL calc_negative_y
                                    
                                    ; INT0 Ķ INT1
00004d e00f                         LDI R16, 0x0F
00004e bf05                         OUT MCUCR, R16
                                 
                                    ; ­Óń­Õ°ÕĒĶÕ INT0, INT1
00004f ec00                         LDI R16, 0xC0
000050 bf0b                         OUT GICR, R16
000051 bf0a                         OUT GIFR, R16
000052 9478                         SEI
                                    
                                 
                                 ; =====================================================
                                 ; ╬č═╬┬═╬╔ ų╚╩╦
                                 ; =====================================================
                                 loop:
                                    ; Õ±ļĶ PD7 Ņ“’¾∙ÕĒÓ - ±Ē “³ ßļŅĻĶ­ŅŌĻ¾ ’ŅŌ“Ņ­ĒŅŃŅ Ō§ŅõÓ
000053 b340                         IN   TMP, PIND
000054 7840                         ANDI TMP, 0b10000000
000055 3040                         CPI  TMP, 0b00000000
000056 f409                         BRNE check_input_start
                                 
000057 27aa                         CLR  INPUT_LOCK
                                 
                                 check_input_start:
                                    ; Õ±ļĶ ¾µÕ ß¹ļĶ Ō ­ÕµĶņÕ ŌŌŅõÓ Ķ PD7 Õ∙Ė õÕ­µÓ“ - ĒÕ Ō§ŅõĶ“³ ’ŅŌ“Ņ­ĒŅ
000058 30a1                         CPI  INPUT_LOCK, 0x01
000059 f041                         BREQ normal_work
                                 
                                    ; Õ±ļĶ PD7 ĒÓµÓ“Ó - ŌŅķ“Ķ Ō ­ÕµĶņ ŌŌŅõÓ
00005a b340                         IN   TMP, PIND
00005b 7840                         ANDI TMP, 0b10000000
00005c 3840                         CPI  TMP, 0b10000000
