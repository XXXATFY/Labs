0000d9 f029                          breq CHECK_BTN1
                                 
0000da d0b0                          rcall SAVE_CURRENT
0000db c003                          rjmp CHECK_BTN1
                                 
                                 BTN0_RELEASED:
0000dc e001                          ldi t0, 1
0000dd 9300 0067                     sts btn0_prev, t0
                                 
