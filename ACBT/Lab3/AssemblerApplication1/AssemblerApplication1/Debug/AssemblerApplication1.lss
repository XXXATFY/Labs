                                 ; Чтение PIN-кода из EEPROM
                                 ; PIN хранится по адресам 0x00, 0x01, 0x02, 0x03
                                 eeprom_read:
                                     ; Чтение PIN0
000083 e000                          LDI  TMP, 0x00
000084 bb0f                          OUT  EEARH, TMP
000085 e000                          LDI  TMP, 0x00
000086 bb0e                          OUT  EEARL, TMP
000087 9ae0                          SBI  EECR, EERE
000088 b3cd                          IN   PIN0, EEDR
                                 
                                     ; Чтение PIN1
000089 e000                          LDI  TMP, 0x00
00008a bb0f                          OUT  EEARH, TMP
00008b e001                          LDI  TMP, 0x01
00008c bb0e                          OUT  EEARL, TMP
00008d 9ae0                          SBI  EECR, EERE
00008e b32d                          IN   PIN1, EEDR
                                 
                                     ; Чтение PIN2
00008f e000                          LDI  TMP, 0x00
000090 bb0f                          OUT  EEARH, TMP
000091 e002                          LDI  TMP, 0x02
000092 bb0e                          OUT  EEARL, TMP
000093 9ae0                          SBI  EECR, EERE
000094 b33d                          IN   PIN2, EEDR
                                 
                                     ; Чтение PIN3
000095 e000                          LDI  TMP, 0x00
000096 bb0f                          OUT  EEARH, TMP
000097 e003                          LDI  TMP, 0x03
000098 bb0e                          OUT  EEARL, TMP
000099 9ae0                          SBI  EECR, EERE
00009a b34d                          IN   PIN3, EEDR
                                 
00009b 9508                          RET
                                 
                                 
                                 ; Инициализация микроконтроллера
                                 reset:
                                     ; Инициализация стека
00009c e008                          LDI  TMP, HIGH(RAMEND)
00009d bf0e                          OUT  SPH, TMP
00009e e50f                          LDI  TMP, LOW(RAMEND)
00009f bf0d                          OUT  SPL, TMP
                                 
                                     ; PORTA - управление разрядами семисегментного индикатора
                                     ; PA0..PA3 - выбор разряда
                                     ; PA6 - индикация ошибки
                                     ; PA7 - индикация правильного PIN-кода
0000a0 ef0f                          SER  TMP
0000a1 bb0a                          OUT  DDRA, TMP
0000a2 2700                          CLR  TMP
0000a3 bb0b                          OUT  PORTA, TMP
                                 
                                     ; PORTC — сегменты семисегментного индикатора
0000a4 ef0f                          SER  TMP
0000a5 bb04                          OUT  DDRC, TMP
0000a6 bb05                          OUT  PORTC, TMP
                                 
                                     ; PORTD:
                                     ; PD0 - кнопка увеличения цифры
                                     ; PD1 - кнопка уменьшения цифры
                                     ; PD2 - INT0, переход к предыдущему разряду
                                     ; PD3 - INT1, переход к следующему разряду / проверка PIN-кода
                                     ; PD4..PD7 — выходы
0000a7 ef00                          LDI  TMP, 0xF0
0000a8 bb01                          OUT  DDRD, TMP
0000a9 2700                          CLR  TMP
0000aa bb02                          OUT  PORTD, TMP
                                 
                                     ; Начальные значения переменных
0000ab e090                          LDI  WRONG, 0x00
0000ac e0a1                          LDI  DIGIT, 0x01
0000ad e010                          LDI  DEL2SEC, 0x00
0000ae e0d0                          LDI  DEL250MS, 0x00
0000af e050                          LDI  SPIN0, 0x00
0000b0 e060                          LDI  SPIN1, 0x00
0000b1 e070                          LDI  SPIN2, 0x00
0000b2 e080                          LDI  SPIN3, 0x00
0000b3 e0c0                          LDI  PIN0, 0x00
0000b4 e020                          LDI  PIN1, 0x00
0000b5 e030                          LDI  PIN2, 0x00
0000b6 e040                          LDI  PIN3, 0x00
0000b7 e0f0                          LDI  BLINK, 0x00
                                 
                                     ; Чтение правильного PIN-кода из EEPROM
                                     ;CALL eeprom_read
                                 
                                     ; Настройка внешних прерываний INT0 и INT1
                                     ; INT0 и INT1 срабатывают по переднему фронту (0 -> 1)
0000b8 e00f                          LDI  R16, 0x0F
0000b9 bf05                          OUT  MCUCR, R16
                                 
                                     ; Разрешение INT0 и INT1
                                     ; GICR = 0xC0: включены INT1 и INT0
0000ba ec00                          LDI  R16, 0xC0
0000bb bf0b                          OUT  GICR, R16
0000bc bf0a                          OUT  GIFR, R16
                                 
                                     ; Timer0 — мигание текущего разряда
                                     ; Режим CTC, предделитель 256
                                     ; OCR0 = 155
                                     ; Период: 156 * 256 / 8 МГц = 5 мс
0000bd e00c                          LDI  TMP, 0x0C
0000be bf03                          OUT  TCCR0, TMP
0000bf e90b                          LDI  TMP, 155
0000c0 bf0c                          OUT  OCR0, TMP
                                 
                                     ; Timer2 — опрос кнопок и временные задержки
                                     ; Режим CTC, предделитель 1024
                                     ; OCR2 = 77
                                     ; Период: 78 * 1024 / 8 МГц = 10 мс
0000c1 e00f                          LDI  TMP, 0x0F
0000c2 bd05                          OUT  TCCR2, TMP
0000c3 e40d                          LDI  TMP, 77
0000c4 bd03                          OUT  OCR2, TMP
                                 
                                     ; Разрешение прерываний по совпадению Timer0 и Timer2
                                     ; TIMSK = 0x82: OCIE2 = 1, OCIE0 = 1
0000c5 e802                          LDI  TMP, 0x82
0000c6 bf09                          OUT  TIMSK, TMP
                                 
                                     ; Глобальное разрешение прерываний
0000c7 9478                          SEI
                                 
                                 
                                 ; Основной цикл программы
                                 ; Поочерёдно выводит четыре цифры PIN-кода на индикатор
                                 loop:
0000c8 30e2                          CPI INPDLOOP, 0x02
0000c9 f171                          BREQ wrong_wait_loop
                                 
0000ca 3f9f                          CPI WRONG, 0xFF
0000cb f089                          BREQ correct_loop
                                 
0000cc e0b1                          LDI SHOW, 0x01
0000cd 2f05                          MOV TMP, SPIN0
0000ce 940e 0100                     CALL show_digit
                                     
0000d0 0fbb                          LSL SHOW
0000d1 2f06                          MOV TMP, SPIN1
0000d2 940e 0100                     CALL show_digit
                                     
0000d4 0fbb                          LSL SHOW
0000d5 2f07                          MOV TMP, SPIN2
0000d6 940e 0100                     CALL show_digit
                                 
0000d8 0fbb                          LSL SHOW
0000d9 2f08                          MOV TMP, SPIN3
0000da 940e 0100                     CALL show_digit
                                 
0000dc cfeb                          RJMP loop
                                 
                                 
                                 ; Режим правильного ввода PIN-кода
                                 ; На индикатор выводится 9999, включается PA7
                                 correct_loop:
0000dd e059                          LDI  SPIN0, 0x09
0000de e069                          LDI  SPIN1, 0x09
0000df e079                          LDI  SPIN2, 0x09
0000e0 e089                          LDI  SPIN3, 0x09
0000e1 e800                          LDI  TMP, 0x80
0000e2 bb0b                          OUT  PORTA, TMP
0000e3 cfe4                          RJMP loop
                                 
                                 
                                 ; Сравнение введённого PIN-кода с правильным PIN-кодом
                                 compare_pins:
0000e4 175c                          CP  SPIN0, PIN0
0000e5 f449                          BRNE wrong_pin
0000e6 1762                          CP  SPIN1, PIN1
0000e7 f439                          BRNE wrong_pin
0000e8 1773                          CP  SPIN2, PIN2
0000e9 f429                          BRNE wrong_pin
0000ea 1784                          CP  SPIN3, PIN3
0000eb f419                          BRNE wrong_pin
                                 
0000ec ef0f                          LDI TMP, 0xFF
0000ed 2f90                          MOV WRONG, TMP
0000ee 9508                          RET
                                 
                                 
                                 ; Обработка неверного PIN-кода
                                 wrong_pin:
0000ef 9593                          INC WRONG
0000f0 3093                          CPI WRONG, 0x03
0000f1 f059                          BREQ lock
                                 
0000f2 e400                          LDI TMP, 0x40
0000f3 bb0b                          OUT PORTA, TMP
                                 
0000f4 e0e2                          LDI INPDLOOP, 0x02
0000f5 e010                          LDI DEL2SEC, 0x00
0000f6 e0d0                          LDI DEL250MS, 0x00
0000f7 9508                          RET
                                 
                                 
                                 ; Ожидание после неверного PIN-кода
                                 wrong_wait_loop:
0000f8 e400                          LDI TMP, 0x40
0000f9 bb0b                          OUT PORTA, TMP
                                 
0000fa 3f9f                          CPI WRONG, 0xFF
0000fb f309                          BREQ correct_loop
                                 
0000fc cfcb                          RJMP loop
                                 
                                 
                                 ; Блокировка после трёх неверных попыток
                                 lock:
0000fd ec00                          LDI TMP, 0xC0
0000fe bb0b                          OUT PORTA, TMP
                                 l:
0000ff cfff                          RJMP l
                                 
                                 
                                 ; Вывод одной цифры на семисегментный индикатор
                                 ; Если отображаемый разряд совпадает с DIGIT, он мигает с частотой 4 Гц
                                 show_digit:
000100 17ba                          CP   SHOW, DIGIT
000101 f429                          BRNE show_num
                                 
                                     ; Фаза выключения мигающего разряда
                                     ; BLINK = 0..24 - разряд выключен
                                     ; BLINK = 25..49 - разряд включен
000102 31f9                          CPI  BLINK, 25
000103 f41c                          BRGE show_num
                                 
000104 2700                          CLR  TMP
000105 bb0b                          OUT  PORTA, TMP
000106 9508                          RET
                                 
                                 show_num:
000107 940e 010f                     CALL code_to_portc
000109 2f0b                          MOV  TMP, SHOW
00010a bb0b                          OUT  PORTA, TMP
00010b 0000                          NOP
00010c 0000                          NOP
00010d 0000                          NOP
00010e 9508                          RET
                                 
                                 
