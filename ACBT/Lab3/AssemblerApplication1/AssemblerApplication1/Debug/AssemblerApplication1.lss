00014a 9518                          RETI
                                 
                                 
                                 ; Прерывание Timer0
                                 ; Timer0 срабатывает каждые 5 мс
                                 TIMER0_COMP_ISR:
00014b 930f                          PUSH TMP
00014c b70f                          IN   TMP, SREG
00014d 930f                          PUSH TMP
00014e 2f0b                          MOV  TMP, SHOW
00014f 930f                          PUSH TMP
                                 
000150 30e2                          CPI  INPDLOOP, 0x02
000151 f031                          BREQ timer0_exit
000152 3f9f                          CPI  WRONG, 0xFF
000153 f021                          BREQ timer0_exit
                                 
                                     ; 25 * 5 мс = 125 мс
                                     ; 50 * 5 мс = 250 мс, то есть частота мигания 4 Гц
000154 95f3                          INC  BLINK
000155 33f2                          CPI  BLINK, 50
000156 f008                          BRLO timer0_exit
000157 e0f0                          LDI  BLINK, 0x00
                                 
                                 timer0_exit:
000158 910f                          POP  TMP
000159 2fb0                          MOV  SHOW, TMP
00015a 910f                          POP  TMP
00015b bf0f                          OUT  SREG, TMP
00015c 910f                          POP  TMP
00015d 9518                          RETI
                                 
                                 
                                 ; Прерывание Timer2
                                 ; Timer2 срабатывает каждые 10 мс
                                 TIMER2_COMP_ISR:
00015e 930f                          PUSH TMP
00015f b70f                          IN   TMP, SREG
000160 930f                          PUSH TMP
000161 2f0b                          MOV  TMP, SHOW
000162 930f                          PUSH TMP
                                 
000163 30e2                          CPI  INPDLOOP, 0x02
000164 f049                          BREQ error_mode_timer2
                                 
000165 3f9f                          CPI  WRONG, 0xFF
000166 f039                          BREQ error_mode_timer2
                                 
000167 30e0                          CPI  INPDLOOP, 0x00
000168 f411                          BRNE skip_check
000169 940e 002e                     CALL check_buttons
                                 
                                 skip_check:
00016b 940e 0015                     CALL calc_delay
00016d c012                          RJMP timer2_exit
                                 
                                 error_mode_timer2:
                                     ; Timer2 срабатывает каждые 10 мс
                                     ; 100 * 10 мс = 1 секунда
00016e 9513                          INC  DEL2SEC
00016f 3614                          CPI  DEL2SEC, 100
000170 f479                          BRNE timer2_exit
                                 
                                     ; Прошла 1 секунда
000171 e010                          LDI  DEL2SEC, 0x00
000172 95d3                          INC  DEL250MS
                                 
                                     ; 20 * 1 секунда = 20 секунд ожидания после ошибки
000173 31d4                          CPI  DEL250MS, 20
000174 f459                          BRNE timer2_exit
                                 
                                     ; Ожидание закончено: сброс введённого PIN-кода и возврат к вводу
000175 2700                          CLR  TMP
000176 bb0b                          OUT  PORTA, TMP
                                 
000177 e0a1                          LDI  DIGIT, 0x01
000178 e0b1                          LDI  SHOW, 0x01
                                 
000179 e050                          LDI  SPIN0, 0x00
00017a e060                          LDI  SPIN1, 0x00
00017b e070                          LDI  SPIN2, 0x00
00017c e080                          LDI  SPIN3, 0x00
                                 
00017d e010                          LDI  DEL2SEC, 0x00
00017e e0d0                          LDI  DEL250MS, 0x00
00017f e0e0                          LDI  INPDLOOP, 0x00
                                 
                                 timer2_exit:
000180 910f                          POP  TMP
000181 2fb0                          MOV  SHOW, TMP
000182 910f                          POP  TMP
000183 bf0f                          OUT  SREG, TMP
000184 910f                          POP  TMP
000185 9518                          RETI
                                 
                                 
                                 ; Прерывание INT1
